# Point the daemon at the absolute env file path if you install it as a service.
# SPARK_ENV_PATH=C:\spark\.env

# Server connection
SPARK_SERVER_URL=http://127.0.0.1:8000
DAEMON_SERVICE_TOKEN=replace-with-a-long-random-token

# Shared wake-word config fallback.
# These values seed SparkAI/config.json when keys are missing there.
WAKE_WORD_PHRASES=hey spark,spark
WAKE_WORD_MODELS=hey_spark,spark
WAKE_WORD_THRESHOLD=0.5
WAKE_WORD_COOLDOWN_S=1.0

# Audio
SAMPLE_RATE=16000
CHUNK_MS=20
# MIC_DEVICE_INDEX=0

# Playback
# DING_WAV_PATH=
DING_VOLUME=1.0
TTS_VOLUME=1.0

# Models
# MODELS_DIR=

# Health / reconnect
HEALTH_POLL_INTERVAL_S=1.0
HEALTH_POLL_TIMEOUT_S=60.0
SOCKET_RECONNECT_ATTEMPTS=0
SOCKET_RECONNECT_DELAY_S=2.0

# Voice activity detection
VAD_POSITIVE_SPEECH_THRESHOLD=0.75
VAD_NEGATIVE_SPEECH_THRESHOLD=0.55
VAD_MIN_SPEECH_MS=500
VAD_REDEMPTION_MS=400
VAD_PRE_SPEECH_PAD_MS=120

# Logging
LOG_LEVEL=INFO
LOG_AUDIO_PAYLOADS=false
